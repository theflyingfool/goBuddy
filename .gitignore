node_modules/
dist/
*.apk
tsconfig.tsbuildinfo

# Release-signing secrets — these live outside the repo entirely, at
# ~/.android-keystores/, and the build only ever reads them from there.
# These patterns are just a backstop against one ending up in a working
# tree by accident.
android/keystore.properties
*.jks
*.keystore
playwright-report/
test-results/
dummy.sqlite
scripts/ingest/.cache/
scripts/ingest/.cache-v2/
data-authoring/reference-export.csv

# V2 exploration DB (data-authoring/v2-explore/) — raw third-party pulls and
# a throwaway SQLite file for ad hoc join exploration, not a real ingestion
# artifact. See docs/v2-schema-design.md.
data-authoring/v2-explore/raw/
data-authoring/v2-explore/*.sqlite
data-authoring/v2-explore/reference-v2-candidate.json

# Loose reference material (old Obsidian vault exports, full-size sprite
# images) already mined into src/data/reference.json and public/sprites/ —
# ~245MB, not worth version-controlling.
Refs from Obsidian/

# Editor lock files
.~lock.*

# Local Claude Code harness config/state — machine-specific, not shared project config
.claude/

# IDE project files (Android Studio/IntelliJ) — machine-local, not shared
# config. Matches both a root .idea/ (opening the whole repo) and
# android/.idea/ (opening just the native project) since this pattern has no
# leading slash.
.idea/

# Obsidian vault config — machine-local, not shared config.
.obsidian/
