{
  "name": "pogo-buddy",
  "private": true,
  "version": "0.17.0",
  "type": "module",
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "tsx --test test/**/*.test.ts",
    "test:e2e": "playwright test",
    "version:bump": "tsx scripts/bump-version.ts",
    "build:dummy-db": "tsx scripts/build-dummy-db.ts",
    "ingest:fetch": "tsx scripts/ingest/fetch-pokeapi-data.ts",
    "ingest:build": "tsx scripts/ingest/build-reference.ts",
    "ingest:csv:export": "tsx scripts/ingest/csv-authoring.ts export",
    "ingest:csv:template": "tsx scripts/ingest/csv-authoring.ts template",
    "ingest:csv:import": "tsx scripts/ingest/csv-authoring.ts import",
    "ingest:events": "tsx scripts/ingest/parse-event-pokemon.ts",
    "ingest:gigantamax": "tsx scripts/ingest/parse-gigantamax.ts",
    "ingest:check-slugs": "tsx scripts/ingest/check-slug-stability.ts",
    "ingest:sprites": "tsx scripts/ingest/build-sprite-mapping.ts",
    "android:sync": "vite build && npx cap sync android",
    "android:build": "npm run android:sync && cd android && ./gradlew assembleDebug",
    "android:release": "npm run android:sync && cd android && ./gradlew assembleRelease",
    "android:export": "export JAVA_HOME=/opt/android-studio/jbr && export ANDROID_HOME=$HOME/Android/Sdk"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.1",
    "@eslint/css": "^1.4.0",
    "@eslint/js": "^9.39.4",
    "@eslint/json": "^2.0.1",
    "@eslint/markdown": "^8.0.3",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.10.0",
    "eslint": "^9.39.4",
    "globals": "^17.7.0",
    "sharp": "^0.35.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.63.0",
    "vite": "^6.0.0",
    "xlsx": "^0.18.5"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "^8.1.0",
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/share": "^8.0.1",
    "jeep-sqlite": "^2.8.0",
    "sql.js": "1.11.0"
  },
  "allowScripts": {
    "sharp@0.32.6": true,
    "sharp@0.35.3": true,
    "esbuild@0.28.1": true,
    "esbuild@0.25.12": true
  }
}
